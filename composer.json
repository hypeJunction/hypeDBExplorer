{
	"name": "hypejunction/hypedbexplorer",
	"version": "6.0.0",
	"type": "elgg-plugin",
	"description": "Database explorer tool for Elgg",
	"homepage": "https://github.com/hypeJunction/hypeDBExplorer",
	"keywords": [
		"elgg",
		"plugin",
		"database",
		"developers",
		"bulk actions"
	],
	"license": "GPL-2.0",
	"authors": [
		{
			"name": "Ismayil Khayredinov",
			"email": "ismayil.khayredinov@gmail.com"
		}
	],
	"require": {
		"php": ">=8.1",
		"elgg/elgg": "^6.0",
		"composer/installers": "^2.0"
	},
	"autoload": {
		"psr-4": {
			"hypeJunction\\DBExplorer\\": "classes/hypeJunction/DBExplorer/"
		}
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true
		}
	},
	"extra": {
		"installer-name": "hypedbexplorer",
		"elgg-plugin": {
			"id": "hypedbexplorer"
		}
	}
}
